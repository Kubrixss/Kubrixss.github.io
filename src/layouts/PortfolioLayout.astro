---
const { frontmatter } = Astro.props;
import Layout from "./Layout.astro";
import { Image } from "astro:assets";
if (frontmatter.trailer) {
  // transform trailer url from https://youtube.com/watch?v=... to https://www.youtube.com/embed/...
  frontmatter.trailer = frontmatter.trailer.replace("watch?v=", "embed/");
}
if (!frontmatter.roles) {
  frontmatter.roles = "Unknown";
} else if (Array.isArray(frontmatter.roles)) {
  frontmatter.roles = frontmatter.roles.join(", ");
}
if (!frontmatter.screenshots) {
  frontmatter.screenshots = [
    {
      url: "https://via.placeholder.com/400",
      alt: "Placeholder",
      description: "Placeholder",
    },
    {
      url: "https://via.placeholder.com/400",
      alt: "Placeholder",
      description: "Placeholder",
    },
  ];
}
if (!frontmatter.platform) {
  frontmatter.platform = "Unknown";
}
if (!frontmatter.engine) {
  frontmatter.engine = "Unknown";
}
if (!frontmatter.link) {
  frontmatter.link = "#";
}

if (!frontmatter.genre) {
  frontmatter.genre = "Unknown";
} else if (Array.isArray(frontmatter.genre)) {
  frontmatter.genre = frontmatter.genre.join(", ");
}

frontmatter.date_created = new Date(
  frontmatter.date_created,
).toLocaleDateString("en-gb", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout title={frontmatter.title}>
  <div class="header">
    <h1>{frontmatter.title}</h1>
    <div id="header-grid">
      <div id="description">
        <h3>{frontmatter.description}</h3>
        <slot />
      </div>
      {
        frontmatter.trailer && (
          <iframe
            width="560"
            height="315"
            src={frontmatter.trailer}
            title="YouTube video player"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          />
        )
      }
    </div>
    <a href={frontmatter.link}>Download Here</a>
  </div>
  <div class="content">
    <div id="date">
      <p id="heading">Release Date</p>
      <p>{frontmatter.date_created}</p>
    </div>
    <div id="roles">
      <p id="heading">Roles</p>
      <p>{frontmatter.roles}</p>
    </div>
    <div id="platform">
      <p id="heading">Platform</p>
      <p>{frontmatter.platform}</p>
    </div>
    <div id="engine">
      <p id="heading">Engine</p>
      <p>{frontmatter.engine}</p>
    </div>
    <div id="genres">
      <p id="heading">Genres</p>
      <p>{frontmatter.genre}</p>
    </div>
  </div>
  <hr />
  <div id="gallery">
    <h2>Screenshots</h2>
    <!-- parse the screenshots array -->
    <div id="screenshots">
      {
        frontmatter.screenshots.map((screenshot) => (
          <div id="screenshot">
            {typeof screenshot.url === "string" ? (
              <Image
                src={screenshot.url}
                alt={screenshot.alt || ""}
                width={400}
                height={400}
              />
            ) : (
              <Image src={screenshot.url} alt={screenshot.alt || ""} />
            )}
            <p>{screenshot.description}</p>
          </div>
        ))
      }
    </div>
  </div>
  <div id="image-modal" class="modal">
    <span class="close">&times;</span>
    <img class="modal-content" id="modal-img" />
    <div id="caption"></div>
  </div>
</Layout>

<script>
  function initModal() {
    const modal = document.getElementById("image-modal");
    const modalImg = document.getElementById("modal-img");
    const captionText = document.getElementById("caption");
    const images = document.querySelectorAll("#screenshots img");
    const span = document.querySelector(".close");

    if (modal && modalImg && images.length > 0) {
      images.forEach((img) => {
        img.onclick = function () {
          modal.style.display = "flex";
          modalImg.src = this.src;
          const p = this.nextElementSibling;
          if (p && p.tagName === "P") {
            captionText.innerHTML = p.innerHTML;
          } else {
            captionText.innerHTML = "";
          }
        };
      });

      if (span) {
        span.onclick = function () {
          modal.style.display = "none";
        };
      }

      modal.onclick = function (e) {
        if (e.target !== modalImg) {
          modal.style.display = "none";
        }
      };
    }
  }
  initModal();
  document.addEventListener("astro:page-load", initModal);
</script>

<style>

  body {
    background: #13151a;
  }

  .header {
    text-align: center;
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    row-gap: 1rem;
  }
  h1 {
    margin: 0;
    padding-bottom: 20px;
  }
  h2 {
    margin-top: 2rem;
    margin-bottom: 1rem;
    text-align: center;
  }
  h3 {
    margin: 0;
    color: white;
  }

  a {
    color: white;
  }
  .content {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    justify-content: center;
    margin-right: 2rem;
    margin-left: 2rem;
  }
  .content div {
    padding: 1rem;
    background-color: #ffffff43;
    margin: 0.5rem;
    box-shadow: 0 0 10px 0 rgba(255, 255, 255, 0.34);
  }
  #date {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  p {
    margin: 0;
    font-size: 16px;
  }
  #heading {
    font-weight: bold;
  }

  hr {
    margin-top: 2rem;
    margin-right: 2rem;
    margin-left: 2rem;
    border: 0;
    border-top: 1px solid #ccc;
  }
  #gallery {
    margin-top: 2rem;
    margin-bottom: 4rem;
  }

  #screenshots {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
    gap: 1rem;
    margin: 0 5rem;
  }

  #header-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 0 5rem;
  }
  #screenshot {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  img {
    width: 100%;
    height: auto;
  }

  #end {
    margin-bottom: 2rem;
  }

  /* make the date div twice the width of the other grid elements */
  #date {
    grid-column: span 2;
  }

  /* Modal Lightbox Styles */
  .modal {
    display: none;
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.85);
    align-items: center;
    justify-content: center;
    flex-direction: column;
    backdrop-filter: blur(5px);
  }

  .modal-content {
    margin: auto;
    display: block;
    max-width: 90%;
    max-height: 80vh;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
    object-fit: contain;
    animation: zoom 0.3s ease-in-out;
  }

  #caption {
    margin: auto;
    display: block;
    width: 80%;
    max-width: 700px;
    text-align: center;
    color: #ccc;
    padding: 15px 0;
    font-size: 1.2rem;
    animation: zoom 0.3s ease-in-out;
  }

  @keyframes zoom {
    from {
      transform: scale(0.9);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }

  .close {
    position: absolute;
    top: 20px;
    right: 40px;
    color: #f1f1f1;
    font-size: 45px;
    font-weight: bold;
    cursor: pointer;
    transition: 0.2s;
    z-index: 1001;
  }

  .close:hover,
  #screenshots img:hover {
    opacity: 0.7;
  }

  #screenshots img {
    cursor: zoom-in;
    transition: 0.3s;
  }
</style>
