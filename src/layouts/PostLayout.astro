---
const { frontmatter } = Astro.props;
import Layout from "./Layout.astro";
// dd--mm--yyyy
frontmatter.pubDate = new Date(frontmatter.pubDate).toLocaleDateString(
  "en-GB",
  {
    day: "numeric",
    month: "long",
    year: "numeric",
  },
);
---

<Layout title={frontmatter.title}>
  <h1>{frontmatter.title}</h1>
  <p>Written by {frontmatter.author}</p>
  <p>Published on {frontmatter.pubDate}</p>
  <hr />
  <div id="post-content">
    <slot />
  </div>
  <br />
</Layout>

<style>

  body {
    background: #13151a;
  }

  h1 {
    text-align: center;
  }
  p {
    text-align: center;
    margin: 0 75px;
    padding-bottom: 10px;
  }
  hr {
    margin: 2rem 300px;
  }

  img {
    max-width: 100%;
    padding: 20px 0 20px 0;
  }
  #post-content {
    margin: 0 200px;
    padding-bottom: 50px;
  }

  a {
    color: #0070f3;
    text-decoration: none;
  }

  a:hover {
    text-decoration: none;
  }
</style>
