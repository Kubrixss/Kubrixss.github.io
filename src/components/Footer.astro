---
import config from "../config.json";
const { email, cv, linkedin } = config;
---

<div id="footer">
  <div id="footer-links">
    <a href="/cv" target="/cv">CV</a>
    <a href={linkedin} target="">LinkedIn</a>
    <a href=`mailto:${email}`>Email</a>
  </div>
</div>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Shantell+Sans:ital,wght@0,300..800;1,300..800&display=swap");
  * {
    font-family: "Shantell Sans", cursive;
  }
  #footer {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100px;
    background-color: #1e1e2e;
    box-shadow: 0px -5px 5px 0px #27272788;
  }

  #footer-links {
    display: flex;
    justify-content: space-around;
    align-items: center;
    width: 200px;
  }

  #footer-links a {
    text-decoration: none;
    color: #fff;
  }
</style>
